# ============================================================
# StockTrader 환경 설정 파일
# 이 파일을 .env 또는 .env.local 로 복사 후 실제 값을 입력하세요.
# ============================================================

# 브로커 선택: paper (모의투자) | kis (한국투자증권 실거래)
BROKER=paper

# Korea Investment & Securities (KIS) API
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=12345678-01
KIS_PRODUCT_CODE=01
# KIS 모드: paper (모의투자) | live (실거래)
KIS_MODE=paper
# KIS_BASE_URL 미설정시 KIS_MODE에 따라 자동 결정
# KIS_BASE_URL=https://openapivts.koreainvestment.com:29443

# Telegram Notification
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Risk Management
RISK_MAX_LOSS_PER_TRADE=30000
RISK_DAILY_LOSS_LIMIT=100000
RISK_MAX_EXPOSURE_PER_SYMBOL=300000
RISK_MAX_CONCURRENT_POSITIONS=3
RISK_LOSS_STREAK_COOLDOWN=3
RISK_COOLDOWN_MINUTES=60
RISK_ASSUMED_STOP_LOSS_PCT=0.015
RISK_TARGET_POSITION_VALUE=100000

# News Ingestion: sample | rss
NEWS_MODE=sample
# NEWS_RSS_URL=https://www.mk.co.kr/rss/30000001/

# Scheduler
EXIT_CYCLE_INTERVAL_SEC=60

# Demo
ENABLE_DEMO_AUTO_CLOSE=0
